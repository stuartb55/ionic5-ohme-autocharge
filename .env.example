# Hyundai Bluelink credentials (European account)
HYUNDAI_USERNAME=your_email@example.com
HYUNDAI_PASSWORD=your_password
HYUNDAI_PIN=1234

# Optional: pin which vehicle to read when the account has more than one (the
# vehicle id from GET /api/vehicles). Blank = first vehicle; the dashboard's
# picker can override this at runtime.
HYUNDAI_VEHICLE_ID=

# Ohme account credentials
OHME_EMAIL=your_email@example.com
OHME_PASSWORD=your_password

# Charge target percentage (default: 80). This is the initial/fallback value;
# once changed from the dashboard the new target is persisted (see SETTINGS_PATH)
# and takes precedence over this on restart.
CHARGE_TARGET=80

# Where runtime-adjustable settings (the charge target) are persisted. Defaults
# to /app/data/settings.json inside the container; the compose files mount a
# named volume there so it survives restarts.
SETTINGS_PATH=/app/data/settings.json

# How often to poll Ohme for plug-in events, in seconds (default: 180)
POLL_INTERVAL=180

# Max seconds to wait on a single upstream call (Hyundai Bluelink / Ohme) before
# treating it as a failed read, so a hung upstream can't stall the poll loop
# (default: 30). The loop keeps the last-known-good data and retries next poll.
UPSTREAM_TIMEOUT=30

# Upper bound (seconds) on the poll loop's back-off during a sustained upstream
# outage (default: 1800 = 30min). After consecutive failed polls the loop waits
# POLL_INTERVAL * 2**(n-1), capped here; it returns to POLL_INTERVAL on success.
MAX_POLL_BACKOFF=1800

# How often to re-read the SOC from Bluelink while a charge is running, in
# seconds (default: 1800 = 30min), so the dashboard battery ring climbs through
# the session. Reads Hyundai's cached state (never wakes the car). 0 disables it.
LIVE_SOC_INTERVAL=1800

# Maximum age in seconds of the Hyundai cached-state SOC accepted for target
# setting (default: 1800 = 30min). Stale data fails safe and is retried. Set 0
# only if your vehicle/region does not expose a state timestamp.
MAX_SOC_AGE=1800

# Timezone for log timestamps and daily-stats date bucketing (default:
# Europe/London — Ohme's per-day stats start at local midnight, so this must
# match the account's home timezone, not the container's UTC default).
TZ=Europe/London

# Ntfy notifications (optional) — leave NTFY_TOPIC blank to disable
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh
NTFY_TOKEN=

# Weekly charging-summary digest via ntfy. Sent on this weekday (0=Mon..6=Sun)
# at this local hour. Set the day outside 0-6 (e.g. -1) to disable. Needs NTFY_TOPIC.
WEEKLY_DIGEST_DAY=0
WEEKLY_DIGEST_HOUR=8

# Web API / dashboard (optional)
# Comma-separated list of allowed CORS origins. Leave blank for same-origin only
# (the default — nginx serves the UI and proxies /api to the backend).
CORS_ORIGINS=

# Postgres history persistence (optional) — for charting in Grafana.
# Leave DATABASE_URL blank to disable; the app then runs entirely in memory.
# The compose files default DATABASE_URL to the bundled Postgres service using
# POSTGRES_PASSWORD below, so normally you only set this to point elsewhere:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=
# Password for the bundled compose Postgres service (and the backend's default
# DATABASE_URL). The port is published on loopback only, but don't keep the
# default if anything else can reach the docker host.
POSTGRES_PASSWORD=autocharge
# How often (seconds) to refresh Ohme's daily totals into Postgres (default 6h).
DAILY_STATS_INTERVAL=21600
# How long (days) to keep per-poll telemetry rows (default 365; 0 = forever).
TELEMETRY_RETENTION_DAYS=365

# Octopus Agile (dynamic tariff) awareness (optional) — set both to enable the
# tariff card. Uses Octopus's public unit-rate API (no account/auth). PRODUCT is
# the current Agile product code; REGION is your single-letter DNO region (A-P).
OCTOPUS_PRODUCT_CODE=
OCTOPUS_REGION=

# Octopus household consumption (optional) — set both to enable the energy-usage
# card (whole-house import vs car charging) and its Postgres history for Grafana.
# Needs an Octopus account (unlike the Agile rates above): API_KEY is the
# account-level API key from your Octopus dashboard; ACCOUNT_NUMBER (e.g.
# A-AAAA1111) lets the app find your electricity import meter automatically.
# Requires DATABASE_URL too (the car portion comes from the telemetry history).
OCTOPUS_API_KEY=
OCTOPUS_ACCOUNT_NUMBER=
