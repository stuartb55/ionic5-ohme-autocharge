{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL",
      "description": "The autocharge PostgreSQL datasource",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-postgresql-datasource",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
        "enable": true,
        "hide": false,
        "iconColor": "green",
        "name": "Plug-in events",
        "rawQuery": "SELECT plugged_in_at AS time, COALESCE(vehicle_name, 'Car') || ' plugged in @ ' || soc_percent || '% → ' || target_percent || '%' AS text, action AS tags FROM charge_sessions WHERE $__timeFilter(plugged_in_at)",
        "target": { "format": "table" }
      }
    ]
  },
  "description": "Ohme + Hyundai IONIQ 5 autocharge: live status, charging trends, daily energy/cost/savings and session history.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["autocharge", "ohme", "ev"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "PostgreSQL",
        "multi": false,
        "name": "DS_POSTGRES",
        "options": [],
        "query": "grafana-postgresql-datasource",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ohme Autocharge",
  "uid": "ohme-autocharge",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "⚡ Live status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "gauge",
      "id": 2,
      "title": "Battery SOC",
      "description": "Most recent state of charge reported by the car.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT battery_percent AS \"SOC\" FROM telemetry WHERE battery_percent IS NOT NULL ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Charging power",
      "description": "Latest power draw at the charger.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT power_watts AS \"Power\" FROM telemetry ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Charger status",
      "description": "Latest reported charger status and plug state.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "mappings": [
            { "type": "value", "options": { "Charging": { "color": "green", "index": 0 } } },
            { "type": "value", "options": { "Finished": { "color": "blue", "index": 1 } } },
            { "type": "value", "options": { "Pending Approval": { "color": "orange", "index": 2 } } },
            { "type": "value", "options": { "Unplugged": { "color": "red", "index": 3 } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "Status", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN connected THEN initcap(replace(COALESCE(charger_status, 'unknown'), '_', ' ')) ELSE 'Unplugged' END AS \"Status\" FROM telemetry ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "This session",
      "description": "Energy delivered in the current/last charging session.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT session_energy_wh / 1000.0 AS \"Session energy\" FROM telemetry ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Current",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "amp", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "orange" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT power_amps AS \"Current\" FROM telemetry ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Voltage",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "volt", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "purple" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT power_volts AS \"Voltage\" FROM telemetry ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "stat",
      "id": 8,
      "title": "Charge target",
      "description": "Stop-charging target currently configured on Ohme.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT target_percent AS \"Target\" FROM telemetry WHERE target_percent IS NOT NULL ORDER BY recorded_at DESC LIMIT 1"
        }
      ]
    },
    {
      "type": "row",
      "id": 9,
      "title": "📈 Charging trends",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Charging power",
      "description": "Power drawn at the charger over time.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "auto"
          },
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["max", "mean"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT recorded_at AS \"time\", power_watts AS \"Power\" FROM telemetry WHERE $__timeFilter(recorded_at) ORDER BY recorded_at"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Battery SOC vs target",
      "description": "Car state of charge against the configured stop target.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Target" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 6] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Battery" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT recorded_at AS \"time\", battery_percent AS \"Battery\", target_percent AS \"Target\" FROM telemetry WHERE $__timeFilter(recorded_at) ORDER BY recorded_at"
        }
      ]
    },
    {
      "type": "row",
      "id": 12,
      "title": "💷 Daily energy, cost & savings",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 13,
      "title": "Total energy",
      "description": "Energy charged across the selected range.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "kwatth", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(energy_wh) / 1000.0 AS \"Total energy\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete"
        }
      ]
    },
    {
      "type": "stat",
      "id": 14,
      "title": "Total cost",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "currencyGBP", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "orange" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(cost_minor) / 100.0 AS \"Total cost\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete"
        }
      ]
    },
    {
      "type": "stat",
      "id": 15,
      "title": "Total savings",
      "description": "Savings vs a flat tariff, as reported by Ohme.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "currencyGBP", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(savings_minor) / 100.0 AS \"Total savings\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete"
        }
      ]
    },
    {
      "type": "stat",
      "id": 16,
      "title": "Avg cost / kWh",
      "description": "Blended cost per kWh over the selected range.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "currencyGBP", "decimals": 3, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(cost_minor) * 10.0 / NULLIF(SUM(energy_wh), 0) AS \"Avg cost/kWh\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete"
        }
      ]
    },
    {
      "type": "barchart",
      "id": 17,
      "title": "Energy charged per day",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 1, "fillOpacity": 80, "gradientMode": "none" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "xField": "Day",
        "showValue": "auto",
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(stat_date, 'Dy DD Mon') AS \"Day\", energy_wh / 1000.0 AS \"Energy\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete ORDER BY stat_date"
        }
      ]
    },
    {
      "type": "barchart",
      "id": 18,
      "title": "Cost vs savings per day",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyGBP",
          "custom": { "lineWidth": 1, "fillOpacity": 80, "gradientMode": "none" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cost" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Savings" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "orientation": "auto",
        "xField": "Day",
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(stat_date, 'Dy DD Mon') AS \"Day\", cost_minor / 100.0 AS \"Cost\", savings_minor / 100.0 AS \"Savings\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete ORDER BY stat_date"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 19,
      "title": "Cumulative savings",
      "description": "Running total of savings over the selected range.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyGBP",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "spanNulls": true
          },
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT stat_date AS \"time\", SUM(savings_minor) OVER (ORDER BY stat_date) / 100.0 AS \"Cumulative savings\" FROM daily_stats WHERE $__timeFilter(stat_date) AND is_complete ORDER BY stat_date"
        }
      ]
    },
    {
      "type": "row",
      "id": 20,
      "title": "🧾 Sessions & schedule",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 21,
      "title": "Plug-ins",
