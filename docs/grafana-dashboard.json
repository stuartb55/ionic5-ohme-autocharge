    {
      "type": "piechart",
      "id": 24,
      "title": "Session outcomes",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 32 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "values": ["value"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT action AS \"metric\", COUNT(*) AS \"value\" FROM charge_sessions WHERE $__timeFilter(plugged_in_at) GROUP BY action ORDER BY \"value\" DESC"
        }
      ]
    },
    {
      "type": "table",
      "id": 25,
      "title": "Recent charge sessions",
      "description": "Session identity, measured energy/cost and reconciliation quality. Null actuals are intentionally not replaced with estimates.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SOC %" }, "properties": [{ "id": "unit", "value": "percent" }] },
          { "matcher": { "id": "byName", "options": "Target %" }, "properties": [{ "id": "unit", "value": "percent" }] },
          { "matcher": { "id": "byName", "options": "Top-up %" }, "properties": [{ "id": "unit", "value": "percent" }] },
          {
            "matcher": { "id": "byName", "options": "Action" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "configured": { "text": "Configured", "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "skipped_at_target": { "text": "Already at target", "color": "yellow", "index": 1 } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "fields": "" },
        "sortBy": [{ "displayName": "Plugged in", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT plugged_in_at AS \"Plugged in\", vehicle_name AS \"Vehicle\", soc_percent AS \"SOC %\", target_percent AS \"Target %\", topup_percent AS \"Top-up %\", actual_energy_wh / 1000.0 AS \"Actual kWh\", actual_cost_minor / 100.0 AS \"Actual cost\", cost_method AS \"Cost method\", tariff_coverage AS \"Tariff coverage\", quality_status AS \"Quality\", action AS \"Action\" FROM charge_sessions WHERE $__timeFilter(plugged_in_at) ORDER BY plugged_in_at DESC LIMIT 100"
        }
      ]
    },
    {
      "type": "table",
      "id": 26,
      "title": "Latest charge schedules",
      "description": "Ohme smart-charge slots captured when each session was configured.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "fields": "" },
        "sortBy": [{ "displayName": "Recorded", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT recorded_at AS \"Recorded\", next_slot_start AS \"Next slot start\", next_slot_end AS \"Next slot end\", slots AS \"Slots\" FROM schedule_snapshots WHERE $__timeFilter(recorded_at) ORDER BY recorded_at DESC LIMIT 20"
        }
      ]
    }
  ]
